   if(tail == NULL){
      cout<<"List is empty, please check again"<<endl;
      return;
   }
   else{
      Node* prev = tail;
      Node* curr = prev->next;
      while(curr->data != value){
         prev = curr;
         curr = curr->next;
      }
      prev->next = curr->next;
